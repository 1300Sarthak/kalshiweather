# wedge configuration — copy to .env and fill in as needed.
#
# Kalshi market data (markets list + orderbooks) is PUBLIC on the current API,
# so NO Kalshi credentials are required for scanning.
#
# ECMWF CDS ensemble is OPTIONAL. If set, wedge fetches the 51-member ensemble
# for direct probability estimates instead of the multi-model normal-CDF approx.
# Leave unset to use the Open-Meteo multi-model fallback (recommended default).
ECMWF_API_KEY=

# Optional overrides for default scan parameters.
# WEDGE_BANKROLL=500
# WEDGE_MIN_EDGE=0.04
# WEDGE_MAX_KELLY=0.25
# WEDGE_FORECAST_DAYS=7
